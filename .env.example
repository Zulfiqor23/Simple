# Copy this file to .env.local and fill in real values
# .env.local is gitignored — NEVER commit real secrets!

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Admin Telegram Chat ID (from @userinfobot)
ADMIN_CHAT_ID=your_admin_chat_id_here

# Google Apps Script URL for file uploads to Google Drive (optional)
NEXT_PUBLIC_GAS_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
